{
  "name": "karen-duix-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=8788 VITE_PORT=5175 concurrently -k \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:emotion\"",
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "dev:emotion": "npm --prefix emotion-avatar-demo run dev",
    "start": "node server/index.js",
    "check": "node --check server/index.js && node --check src/api.js && node --check src/duixClient.js && node --check src/main.js && node --check vite.config.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "duix-guiji-light": "^0.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "concurrently": "^10.0.3",
    "vite": "^8.0.16"
  }
}
